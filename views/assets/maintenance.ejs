<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Maintenance | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">
    <h2>🔧 Maintenance Records — <%= asset.name %></h2>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <!-- Add Maintenance Form -->
    <% if (user.role === 'admin' || user.role === 'it_staff') { %>
    <div class="form-card" style="margin-bottom:2rem">
      <h3 style="margin-bottom:1rem">Add Maintenance Record</h3>
      <form action="/assets/maintenance/<%= asset.id %>" method="POST">

        <div class="form-group">
          <label>Description</label>
          <textarea name="description" placeholder="What was done..." rows="3" required></textarea>
        </div>

        <div class="form-group">
          <label>Maintenance Date</label>
          <input type="date" name="maintenanceDate" required />
        </div>

        <div class="form-group">
          <label>Cost (optional)</label>
          <input type="number" name="cost" placeholder="e.g. 500" step="0.01" />
        </div>

        <div class="form-group">
          <label>Performed By</label>
          <input type="text" name="performedBy" placeholder="e.g. John Tech" />
        </div>

        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="completed">Completed</option>
            <option value="in_progress">In Progress</option>
            <option value="scheduled">Scheduled</option>
          </select>
        </div>

        <button type="submit" class="btn blue">Add Record</button>
      </form>
    </div>
    <% } %>

    <!-- Maintenance Records Table -->
    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Description</th>
          <th>Date</th>
          <th>Cost</th>
          <th>Performed By</th>
          <th>Status</th>
          <th>Logged By</th>
          <% if (user.role === 'admin' || user.role === 'it_staff') { %>
            <th>Actions</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (records.length === 0) { %>
          <tr>
            <td colspan="8" style="text-align:center">No maintenance records found</td>
          </tr>
        <% } %>
        <% records.forEach((r, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= r.description %></td>
            <td><%= r.maintenanceDate %></td>
            <td><%= r.cost ? '₹' + r.cost : '-' %></td>
            <td><%= r.performedBy || '-' %></td>
            <td><span class="badge <%= r.status %>"><%= r.status %></span></td>
            <td><%= r.loggedByUser ? r.loggedByUser.name : '-' %></td>
            <% if (user.role === 'admin' || user.role === 'it_staff') { %>
              <td>
                <form action="/assets/maintenance/<%= asset.id %>/delete/<%= r.id %>" method="POST" style="display:inline">
                  <button type="submit" class="btn-sm red" onclick="return confirm('Delete this record?')">Delete</button>
                </form>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>