<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>User Report | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    @media print {
      .no-print { display: none !important; }
      body { background: white; }
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="page-container">

    <div class="page-header no-print">
      <h2>👥 User Report</h2>
      <div style="display:flex; gap:1rem">
        <a href="/reports" class="btn" style="background:#f0f0f0; color:#555">← Back</a>
        <button onclick="window.print()" class="btn blue">🖨️ Print / Save PDF</button>
      </div>
    </div>

    <!-- FILTER -->
    <form method="GET" action="/reports/users" class="no-print"
      style="display:flex; gap:1rem; margin-bottom:2rem">
      <select name="department"
        style="padding:0.6rem 1rem; border:1px solid #ddd; border-radius:8px">
        <option value="all" <%= selectedDept === 'all' ? 'selected' : '' %>>All Departments</option>
        <% departments.forEach(d => { %>
          <option value="<%= d.name %>" <%= selectedDept === d.name ? 'selected' : '' %>><%= d.name %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn blue">Filter</button>
      <a href="/reports/users" class="btn" style="background:#f0f0f0; color:#555">Clear</a>
    </form>

    <!-- SUMMARY CARDS -->
    <div class="cards" style="margin-bottom:2rem">
      <div class="card blue">
        <h3><%= totalUsers %></h3>
        <p>Total Users</p>
      </div>
      <div class="card green">
        <h3><%= activeUsers %></h3>
        <p>Active</p>
      </div>
      <div class="card red">
        <h3><%= inactiveUsers %></h3>
        <p>Inactive</p>
      </div>
      <div class="card orange">
        <h3><%= adminUsers %></h3>
        <p>Dept Admins</p>
      </div>
    </div>

    <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1rem; text-align:right">
      Generated: <%= new Date().toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) %>
    </p>

    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>Department</th>
          <th>Role</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((u, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><strong><%= u.name %></strong></td>
            <td><%= u.email %></td>
            <td><%= u.department || '-' %></td>
            <td><span class="badge medium"><%= u.role %></span></td>
            <td>
              <span class="badge <%= u.isActive ? 'available' : 'critical' %>">
                <%= u.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>