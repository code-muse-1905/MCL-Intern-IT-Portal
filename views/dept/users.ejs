<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Department Users | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">
    <div class="page-header">
      <h2>👥 <%= user.department %> Department Users</h2>
    </div>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length === 0) { %>
          <tr>
            <td colspan="5" style="text-align:center; color:#888">No users found</td>
          </tr>
        <% } %>
        <% users.forEach((u, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><strong><%= u.name %></strong></td>
            <td><%= u.email %></td>
            <td><span class="badge <%= u.role %>"><%= u.role %></span></td>
            <td>
              <span class="badge <%= u.isActive ? 'available' : 'retired' %>">
                <%= u.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>