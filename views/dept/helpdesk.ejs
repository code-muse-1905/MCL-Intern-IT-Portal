<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Helpdesk | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">
    <div class="page-header">
      <h2>🎫 Helpdesk — <%= dept %> Department</h2>
    </div>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Title</th>
          <th>Raised By</th>
          <th>Category</th>
          <th>Priority</th>
          <th>Related Asset</th>
          <th>Files</th>
          <th>Dept Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (tickets.length === 0) { %>
          <tr>
            <td colspan="10" style="text-align:center; color:#888">No tickets found</td>
          </tr>
        <% } %>
        <% tickets.forEach((t, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= t.title %></td>
            <td><%= t.raisedByUser ? t.raisedByUser.name : '-' %></td>
            <td><%= t.category || '-' %></td>
            <td>
              <span class="badge <%= t.priority === 'critical' ? 'critical' : t.priority === 'high' ? 'medium' : 'available' %>">
                <%= t.priority %>
              </span>
            </td>
            <td>
              <%= t.relatedAsset ? t.relatedAsset.name + ' (' + t.relatedAsset.serialNumber + ')' : '-' %>
            </td>
            <td>
              <% if (t.imageUrl) { %>
                <a href="<%= t.imageUrl %>" target="_blank">🖼</a>
              <% } %>
              <% if (t.docUrl) { %>
                <a href="<%= t.docUrl %>" target="_blank">📄</a>
              <% } %>
              <% if (!t.imageUrl && !t.docUrl) { %>-<% } %>
            </td>
            <td>
              <span class="badge <%= t.deptAdminStatus === 'approved' ? 'available' : t.deptAdminStatus === 'rejected' ? 'critical' : 'medium' %>">
                <%= t.deptAdminStatus %>
              </span>
            </td>
            <td><%= new Date(t.createdAt).toLocaleDateString() %></td>
            <td>
              <% if (t.deptAdminStatus === 'pending') { %>
                <!-- APPROVE -->
                <form action="/dept/helpdesk/<%= t.id %>/approve" method="POST" style="display:inline">
                  <input type="hidden" name="note" value="">
                  <button type="submit" class="btn-sm green">✅ Approve</button>
                </form>
                <!-- REJECT -->
                <form action="/dept/helpdesk/<%= t.id %>/reject" method="POST" style="display:inline">
                  <input type="hidden" name="note" value="">
                  <button type="submit" class="btn-sm red" onclick="return confirm('Reject this ticket?')">❌ Reject</button>
                </form>
              <% } else { %>
                <span style="color:#888; font-size:0.85rem">
                  <%= t.deptAdminStatus === 'approved' ? '✅ Forwarded to SuperAdmin' : '❌ Rejected' %>
                </span>
                <% if (t.deptAdminNote) { %>
                  <br><small style="color:#aaa"><%= t.deptAdminNote %></small>
                <% } %>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>