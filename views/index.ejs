<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Tickets | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav class="navbar">
    <div class="nav-brand">🖥️ IT Asset Portal</div>
    <div class="nav-links">
      <span>👤 <%= user.name %> (<%= user.role %>)</span>
      <a href="/dashboard">Dashboard</a>
      <a href="/logout" style="background:#e74c3c">Logout</a>
    </div>
  </nav>

  <div class="page-container">
    <div class="page-header">
      <h2>🎫 Helpdesk Tickets</h2>
      <a href="/tickets/create" class="btn green">+ Raise Ticket</a>
    </div>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Title</th>
          <th>Priority</th>
          <th>Status</th>
          <th>Raised By</th>
          <th>Assigned To</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (tickets.length === 0) { %>
          <tr>
            <td colspan="7" style="text-align:center">No tickets found</td>
          </tr>
        <% } %>
        <% tickets.forEach((ticket, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= ticket.title %></td>
            <td>
              <span class="badge <%= ticket.priority %>"><%= ticket.priority %></span>
            </td>
            <td>
              <span class="badge <%= ticket.status %>"><%= ticket.status %></span>
            </td>
            <td><%= ticket.raisedByUser ? ticket.raisedByUser.name : '-' %></td>
            <td><%= ticket.assignedToUser ? ticket.assignedToUser.name : 'Unassigned' %></td>
            <td>
              <a href="/tickets/<%= ticket.id %>" class="btn-sm blue">View</a>
              <% if (user.role === 'admin' || user.role === 'it_staff') { %>
                <form action="/tickets/<%= ticket.id %>/delete" method="POST" style="display:inline">
                  <button type="submit" class="btn-sm red" onclick="return confirm('Delete this ticket?')">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>