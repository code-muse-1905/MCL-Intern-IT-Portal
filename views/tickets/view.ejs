<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>View Ticket | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <!-- TICKET HEADER -->
    <div class="asset-header">
      <div class="asset-header-left">
        <div class="asset-icon">🎫</div>
        <div>
          <h2><%= ticket.title %></h2>
          <p style="color:#888; font-size:0.9rem">
            TKT-<%= String(ticket.id).padStart(4, '0') %> •
            Raised by <%= ticket.raisedByUser ? ticket.raisedByUser.name : '-' %> •
            <%= new Date(ticket.createdAt).toLocaleDateString() %>
          </p>
        </div>
      </div>
      <div class="asset-header-right">
        <span class="badge <%= ticket.priority %>"><%= ticket.priority %></span>
        <span class="badge <%= ticket.status %>"><%= ticket.status %></span>
      </div>
    </div>

    <!-- TICKET DETAILS + UPDATE -->
    <div class="detail-card">
      <div class="detail-section">
        <p class="section-label">TICKET INFORMATION</p>
        <table class="detail-table">
          <tr>
            <th>Description</th>
            <td><%= ticket.description %></td>
          </tr>
          <tr>
            <th>Category</th>
            <td><%= ticket.category || '—' %></td>
          </tr>
          <tr>
            <th>Raised By</th>
            <td><%= ticket.raisedByUser ? ticket.raisedByUser.name : '—' %></td>
          </tr>
          <tr>
            <th>Assigned To</th>
            <td><%= ticket.assignedToUser ? ticket.assignedToUser.name : 'Unassigned' %></td>
          </tr>
          <tr>
            <th>Created At</th>
            <td><%= new Date(ticket.createdAt).toLocaleString() %></td>
          </tr>
          <% if (ticket.resolvedAt) { %>
          <tr>
            <th>Resolved At</th>
            <td><%= new Date(ticket.resolvedAt).toLocaleString() %></td>
          </tr>
          <% } %>
          <% if (ticket.attachment) { %>
          <tr>
            <th>Attachment</th>
            <td><a href="<%= ticket.attachment %>" target="_blank" class="btn-sm blue">View Attachment</a></td>
          </tr>
          <% } %>
        </table>
      </div>

      <!-- UPDATE FORM -->
      <% if (user.role === 'admin' || user.role === 'it_staff') { %>
      <div class="detail-section">
        <p class="section-label">UPDATE TICKET</p>
        <form action="/tickets/<%= ticket.id %>/update" method="POST">

          <div class="form-group">
            <label>Status</label>
            <select name="status">
              <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
              <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
              <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
              <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </div>

          <div class="form-group">
            <label>Assign To</label>
            <select name="assignedTo">
              <option value="">Unassigned</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>" <%= ticket.assignedTo === u.id ? 'selected' : '' %>><%= u.name %> (<%= u.role %>)</option>
              <% }) %>
            </select>
          </div>

          <button type="submit" class="btn blue">Update Ticket</button>
        </form>
      </div>
      <% } %>
    </div>

    <!-- TABS -->
    <div class="tabs-container">
      <div class="tabs">
        <button class="tab active" onclick="showTab('comments', event)">
          💬 Comments (<%= ticket.comments ? ticket.comments.length : 0 %>)
        </button>
        <button class="tab" onclick="showTab('history', event)">
          📋 Resolution History
        </button>
      </div>

      <!-- COMMENTS TAB -->
      <div id="tab-comments" class="tab-content active">

        <!-- Add Comment Form -->
        <form action="/tickets/<%= ticket.id %>/comment" method="POST" style="margin-bottom:1.5rem">
          <div class="form-group">
            <label>Add Comment</label>
            <textarea name="comment" placeholder="Write a comment..." rows="3" required></textarea>
          </div>
          <button type="submit" class="btn blue">💬 Post Comment</button>
        </form>

        <!-- Comments List -->
        <% if (ticket.comments && ticket.comments.length === 0) { %>
          <p style="color:#888; text-align:center">No comments yet</p>
        <% } %>
        <% ticket.comments && ticket.comments.forEach(c => { %>
          <div class="comment-card">
            <div class="comment-header">
              <div>
                <strong><%= c.commentUser ? c.commentUser.name : '—' %></strong>
                <span class="badge <%= c.commentUser ? c.commentUser.role : '' %>" style="margin-left:0.5rem; font-size:0.75rem">
                  <%= c.commentUser ? c.commentUser.role : '' %>
                </span>
              </div>
              <div style="display:flex; align-items:center; gap:1rem">
                <span style="color:#aaa; font-size:0.82rem"><%= new Date(c.createdAt).toLocaleString() %></span>
                <% if (user.role === 'admin' || user.id === c.userId) { %>
                  <form action="/tickets/<%= ticket.id %>/comment/<%= c.id %>/delete" method="POST" style="display:inline">
                    <button type="submit" class="btn-sm red" onclick="return confirm('Delete comment?')">🗑</button>
                  </form>
                <% } %>
              </div>
            </div>
            <p class="comment-body"><%= c.comment %></p>
          </div>
        <% }) %>
      </div>

      <!-- HISTORY TAB -->
      <div id="tab-history" class="tab-content">
        <table class="table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Details</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>🎫 Ticket Raised</td>
              <td>By <%= ticket.raisedByUser ? ticket.raisedByUser.name : '—' %></td>
              <td><%= new Date(ticket.createdAt).toLocaleString() %></td>
            </tr>
            <% if (ticket.assignedToUser) { %>
            <tr>
              <td>👤 Assigned</td>
              <td>To <%= ticket.assignedToUser.name %></td>
              <td>—</td>
            </tr>
            <% } %>
            <% if (ticket.resolvedAt) { %>
            <tr>
              <td>✅ Resolved</td>
              <td>Status changed to resolved</td>
              <td><%= new Date(ticket.resolvedAt).toLocaleString() %></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div style="margin-top:1.5rem">
      <a href="/tickets" class="btn" style="background:#f0f0f0; color:#555">← Back to Tickets</a>
    </div>

  </div>

  <script>
    function showTab(name, event) {
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      event.target.classList.add('active');
    }
  </script>

</body>
</html>