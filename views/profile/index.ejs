<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Profile | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">
    <h2>👤 My Profile</h2>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <!-- Profile Info -->
    <div class="form-card" style="margin-bottom:2rem">
      <h3 style="margin-bottom:1rem">Personal Information</h3>
      <form action="/profile" method="POST">

        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" value="<%= profileUser.name %>" required />
        </div>

        <div class="form-group">
          <label>Email</label>
          <input type="email" value="<%= profileUser.email %>" disabled />
          <small style="color:#999">Email cannot be changed</small>
        </div>

        <div class="form-group">
          <label>Role</label>
          <input type="text" value="<%= profileUser.role %>" disabled />
          <small style="color:#999">Role can only be changed by admin</small>
        </div>

        <div class="form-group">
          <label>Department</label>
          <input type="text" name="department" value="<%= profileUser.department || '' %>" placeholder="Your department" />
        </div>

        <button type="submit" class="btn blue">Update Profile</button>
      </form>
    </div>

    <!-- Change Password -->
    <div class="form-card">
      <h3 style="margin-bottom:1rem">Change Password</h3>
      <form action="/profile/password" method="POST">

        <div class="form-group">
          <label>Current Password</label>
          <input type="password" name="currentPassword" placeholder="Enter current password" required />
        </div>

        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="newPassword" placeholder="Enter new password" required />
        </div>

        <div class="form-group">
          <label>Confirm New Password</label>
          <input type="password" name="confirmPassword" placeholder="Confirm new password" required />
        </div>

        <button type="submit" class="btn blue">Change Password</button>
      </form>
    </div>

  </div>

</body>
</html>