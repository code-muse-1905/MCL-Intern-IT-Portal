<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Assets | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">
    <div class="page-header">
      <h2>📦 IT Assets</h2>
     <% if (user.role === 'superadmin' || user.role === 'admin') { %>
  <a href="/assets/add/new" class="btn green">+ Add Asset</a>
<% } %>
    </div>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Type</th>
          <th>Serial Number</th>
          <th>Status</th>
          <th>Assigned To</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (assets.length === 0) { %>
          <tr>
            <td colspan="7" style="text-align:center; color:#888">No assets found</td>
          </tr>
        <% } %>
        <% assets.forEach((asset, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td>
              <a href="/assets/<%= asset.id %>" style="color:#667eea; font-weight:600">
                <%= asset.name %>
              </a>
            </td>
            <td><%= asset.type %></td>
            <td><%= asset.serialNumber || '-' %></td>
            <td>
              <span class="badge <%= asset.status %>"><%= asset.status %></span>
            </td>
            <td><%= asset.assignedUser ? asset.assignedUser.name : 'Unassigned' %></td>
            <td>
              <% if (user.role === 'superadmin' || user.role === 'admin') { %>
                <a href="/assets/<%= asset.id %>/allocate" class="btn-sm blue">Allocate</a>
                <a href="/assets/edit/<%= asset.id %>" class="btn-sm orange">Edit</a>
                <a href="/assets/transfer/<%= asset.id %>" class="btn-sm green">Transfer</a>
                <form action="/assets/delete/<%= asset.id %>" method="POST" style="display:inline">
                  <button type="submit" class="btn-sm red" onclick="return confirm('Delete this asset?')">Delete</button>
                </form>
              <% } else { %>
                <a href="/assets/<%= asset.id %>" class="btn-sm blue">View</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>