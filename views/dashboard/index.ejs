<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">

    <!-- PAGE TITLE -->
    <div style="margin-bottom:2rem">
      <h2 style="font-size:1.6rem; font-weight:700; color:var(--text-main)">
        <% if (role === 'admin') { %>
          <%= user.department %> Department
        <% } else { %>
          My Dashboard
        <% } %>
      </h2>
      <p style="color:var(--text-muted); font-size:0.95rem">
        <%= new Date().toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %>
      </p>
    </div>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <!-- ── DEPT ADMIN ──────────────────────────── -->
    <% if (role === 'admin') { %>

    <div class="cards">
      <div class="card blue">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= totalUsers %></h3>
            <p>Dept Users</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">👥</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/dept/users" style="font-size:0.8rem; color:var(--primary-600); text-decoration:none; font-weight:500">View Users →</a>
        </div>
      </div>

      <div class="card red">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= openTickets %></h3>
            <p>Open Tickets</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">🎫</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/dept/helpdesk" style="font-size:0.8rem; color:#ef4444; text-decoration:none; font-weight:500">View Helpdesk →</a>
        </div>
      </div>

      <div class="card green">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= totalAssets %></h3>
            <p>Dept Assets</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">📦</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/assets" style="font-size:0.8rem; color:#10b981; text-decoration:none; font-weight:500">View Assets →</a>
        </div>
      </div>

      <div class="card orange">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= totalDocuments %></h3>
            <p>Documents</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">📄</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/documents" style="font-size:0.8rem; color:#f59e0b; text-decoration:none; font-weight:500">View Docs →</a>
        </div>
      </div>
    </div>

    <!-- CHARTS -->
    <div style="display:grid; grid-template-columns:1fr 1.5fr; gap:2rem; margin-top:2rem">
      <div class="quick-links">
        <h3 style="margin-bottom:1.5rem">Asset Status</h3>
        <canvas id="assetDoughnut2" height="220"></canvas>
      </div>
      <div class="quick-links">
        <h3 style="margin-bottom:1.5rem">Ticket Status</h3>
        <canvas id="ticketBar" height="220"></canvas>
      </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="quick-links" style="margin-top:2rem">
      <h3 style="margin-bottom:1.25rem">Quick Actions</h3>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem">
        <a href="/dept/users" style="text-decoration:none">
          <div style="background:var(--primary-50); border:1px solid var(--primary-100); border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">👥</div>
            <div style="font-size:0.85rem; font-weight:600; color:var(--primary-700)">My Dept</div>
          </div>
        </a>
        <a href="/assets" style="text-decoration:none">
          <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">📦</div>
            <div style="font-size:0.85rem; font-weight:600; color:#15803d">Assets</div>
          </div>
        </a>
        <a href="/dept/helpdesk" style="text-decoration:none">
          <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">🎫</div>
            <div style="font-size:0.85rem; font-weight:600; color:#991b1b">Helpdesk</div>
          </div>
        </a>
        <a href="/documents" style="text-decoration:none">
          <div style="background:#fffbeb; border:1px solid #fde68a; border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">📄</div>
            <div style="font-size:0.85rem; font-weight:600; color:#92400e">Documents</div>
          </div>
        </a>
      </div>
    </div>

    <!-- ── EMPLOYEE ────────────────────────────── -->
    <% } else { %>

    <div class="cards">
      <div class="card blue">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= totalAssets %></h3>
            <p>My Assets</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">📦</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/assets" style="font-size:0.8rem; color:var(--primary-600); text-decoration:none; font-weight:500">View Assets →</a>
        </div>
      </div>

      <div class="card red">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= openTickets %></h3>
            <p>My Tickets</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">🎫</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/tickets" style="font-size:0.8rem; color:#ef4444; text-decoration:none; font-weight:500">View Tickets →</a>
        </div>
      </div>

      <div class="card green">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= totalDocuments %></h3>
            <p>Documents</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">📄</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/documents" style="font-size:0.8rem; color:#10b981; text-decoration:none; font-weight:500">View Docs →</a>
        </div>
      </div>

      <div class="card orange">
        <div style="display:flex; justify-content:space-between; align-items:flex-start">
          <div>
            <h3><%= user.department %></h3>
            <p>My Department</p>
          </div>
          <div style="font-size:2rem; opacity:0.3">🏢</div>
        </div>
        <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border-light)">
          <a href="/profile" style="font-size:0.8rem; color:#f59e0b; text-decoration:none; font-weight:500">My Profile →</a>
        </div>
      </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="quick-links" style="margin-top:2rem">
      <h3 style="margin-bottom:1.25rem">Quick Actions</h3>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem">
        <a href="/tickets/create" style="text-decoration:none">
          <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">🎫</div>
            <div style="font-size:0.85rem; font-weight:600; color:#991b1b">Raise Ticket</div>
          </div>
        </a>
        <a href="/requests" style="text-decoration:none">
          <div style="background:var(--primary-50); border:1px solid var(--primary-100); border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">📦</div>
            <div style="font-size:0.85rem; font-weight:600; color:var(--primary-700)">My Requests</div>
          </div>
        </a>
        <a href="/documents" style="text-decoration:none">
          <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">📄</div>
            <div style="font-size:0.85rem; font-weight:600; color:#15803d">Documents</div>
          </div>
        </a>
        <a href="/profile" style="text-decoration:none">
          <div style="background:#fffbeb; border:1px solid #fde68a; border-radius:var(--radius-md); padding:1.25rem; text-align:center">
            <div style="font-size:1.75rem; margin-bottom:0.5rem">👤</div>
            <div style="font-size:0.85rem; font-weight:600; color:#92400e">My Profile</div>
          </div>
        </a>
      </div>
    </div>

    <% } %>

  </div>

  <script>
    <% if (role === 'admin') { %>
    new Chart(document.getElementById('assetDoughnut2'), {
      type: 'doughnut',
      data: {
        labels: ['Available', 'Assigned', 'Maintenance'],
        datasets: [{
          data: [<%= availableAssets %>, <%= assignedAssets %>, <%= maintenanceAssets %>],
          backgroundColor: ['#43D9A2', '#6C63FF', '#FF6B6B'],
          borderWidth: 3,
          borderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        cutout: '65%',
        plugins: {
          legend: {
            position: 'bottom',
            labels: { padding: 20, font: { size: 12 }, usePointStyle: true }
          }
        }
      }
    });

    new Chart(document.getElementById('ticketBar'), {
      type: 'bar',
      data: {
        labels: ['Open', 'In Progress', 'Resolved', 'Closed'],
        datasets: [{
          label: 'Tickets',
          data: [<%= openTickets %>, <%= inProgressTickets %>, <%= resolvedTickets %>, <%= closedTickets %>],
          backgroundColor: ['#FF6B6B', '#FFA94D', '#43D9A2', '#6C63FF'],
          borderRadius: 8,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f0f0f0' } },
          x: { grid: { display: false } }
        }
      }
    });
    <% } %>
  </script>

</body>
</html>