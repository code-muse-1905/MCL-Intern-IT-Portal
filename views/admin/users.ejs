<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Manage Users | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="page-container">
    <div class="page-header">
      <h2>👥 Manage Users</h2>
    </div>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <table class="table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Department</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length === 0) { %>
          <tr>
            <td colspan="7" style="text-align:center">No users found</td>
          </tr>
        <% } %>
        <% users.forEach((u, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td>
              <!-- Change Role Form -->
              <form action="/admin/users/<%= u.id %>/role" method="POST" style="display:inline">
                <select name="role" onchange="this.form.submit()">
                  <option value="employee" <%= u.role === 'employee' ? 'selected' : '' %>>Employee</option>
                  <option value="it_staff" <%= u.role === 'it_staff' ? 'selected' : '' %>>IT Staff</option>
                  <option value="manager" <%= u.role === 'manager' ? 'selected' : '' %>>Manager</option>
                  <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                </select>
              </form>
            </td>
            <td><%= u.department || '-' %></td>
            <td>
              <span class="badge <%= u.isActive ? 'available' : 'retired' %>">
                <%= u.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td>
              <!-- Activate/Deactivate -->
              <form action="/admin/users/<%= u.id %>/toggle" method="POST" style="display:inline">
                <button type="submit" class="btn-sm <%= u.isActive ? 'orange' : 'green' %>">
                  <%= u.isActive ? 'Deactivate' : 'Activate' %>
                </button>
              </form>
              <!-- Delete -->
              <form action="/admin/users/<%= u.id %>/delete" method="POST" style="display:inline">
                <button type="submit" class="btn-sm red" onclick="return confirm('Delete this user?')">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>