<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard | IT Portal</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="dashboard-container">

    <h2>Welcome, <%= user.name %>! 👋</h2>
    <p>
      <% if (role === 'superadmin') { %>
        System Administrator — Full Control
      <% } else if (role === 'admin') { %>
        <%= user.department %> Department Admin
      <% } else { %>
        <%= user.department %> — <%= user.role %>
      <% } %>
    </p>

    <% if (success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <!-- ── SUPERADMIN ─────────────────────────── -->
    <% if (role === 'superadmin') { %>
    <div class="cards">
      <div class="card blue">
        <h3><%= totalUsers %></h3>
        <p>Total Users</p>
      </div>
      <div class="card red">
        <h3><%= openTickets %></h3>
        <p>Open Tickets</p>
      </div>
      <div class="card green">
        <h3><%= totalAssets %></h3>
        <p>Total Assets</p>
      </div>
      <div class="card orange">
        <h3><%= totalDepartments %></h3>
        <p>Departments</p>
      </div>
    </div>

    <!-- CHARTS -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-top:2rem">
      <div class="form-card" style="padding:1.5rem">
        <h3 style="margin-bottom:1rem">🍩 Asset Status Distribution</h3>
        <canvas id="assetDoughnut" height="250"></canvas>
      </div>
      <div class="form-card" style="padding:1.5rem">
        <h3 style="margin-bottom:1rem">📊 Assets by Department</h3>
        <canvas id="assetBar" height="250"></canvas>
      </div>
    </div>

    <div class="quick-links" style="margin-top:2rem">
      <h3>Quick Actions</h3>
      <div class="links">
        <a href="/superadmin" class="btn blue">🔧 Super Admin Panel</a>
        <a href="/superadmin/departments" class="btn green">🏢 Departments</a>
        <a href="/superadmin/users" class="btn orange">👥 All Users</a>
        <a href="/assets" class="btn blue">📦 Assets</a>
        <a href="/tickets" class="btn red">🎫 Tickets</a>
        <a href="/reports" class="btn green">📊 Reports</a>
      </div>
    </div>

    <!-- ── DEPT ADMIN ──────────────────────────── -->
    <% } else if (role === 'admin') { %>
    <div class="cards">
      <div class="card blue">
        <h3><%= totalUsers %></h3>
        <p>Dept Users</p>
      </div>
      <div class="card red">
        <h3><%= openTickets %></h3>
        <p>Open Tickets</p>
      </div>
      <div class="card green">
        <h3><%= totalAssets %></h3>
        <p>Dept Assets</p>
      </div>
      <div class="card orange">
        <h3><%= totalDocuments %></h3>
        <p>Documents</p>
      </div>
    </div>

    <!-- CHARTS -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-top:2rem">
      <div class="form-card" style="padding:1.5rem">
        <h3 style="margin-bottom:1rem">📦 Asset Status</h3>
        <canvas id="assetDoughnut2" height="250"></canvas>
      </div>
      <div class="form-card" style="padding:1.5rem">
        <h3 style="margin-bottom:1rem">🎫 Ticket Status</h3>
        <canvas id="ticketBar" height="250"></canvas>
      </div>
    </div>

    <div class="quick-links" style="margin-top:2rem">
      <h3>Quick Actions</h3>
      <div class="links">
        <a href="/dept/users" class="btn blue">👥 My Dept Users</a>
        <a href="/assets" class="btn green">📦 Dept Assets</a>
        <a href="/dept/helpdesk" class="btn red">🎫 Helpdesk</a>
        <a href="/documents" class="btn orange">📄 Documents</a>
      </div>
    </div>

    <!-- ── EMPLOYEE ────────────────────────────── -->
    <% } else { %>
    <div class="cards">
      <div class="card blue">
        <h3><%= totalAssets %></h3>
        <p>My Assets</p>
      </div>
      <div class="card red">
        <h3><%= openTickets %></h3>
        <p>My Tickets</p>
      </div>
      <div class="card green">
        <h3><%= totalDocuments %></h3>
        <p>Documents</p>
      </div>
      <div class="card orange">
        <h3>📋</h3>
        <p>My Profile</p>
      </div>
    </div>

    <div class="quick-links" style="margin-top:2rem">
      <h3>Quick Actions</h3>
      <div class="links">
        <a href="/tickets/create" class="btn red">🎫 Raise Ticket</a>
        <a href="/tickets" class="btn blue">📋 My Tickets</a>
        <a href="/documents" class="btn green">📄 Documents</a>
        <a href="/profile" class="btn orange">👤 My Profile</a>
      </div>
    </div>
    <% } %>

  </div>

  <script>
    // ── SUPERADMIN CHARTS ──────────────────────
    <% if (role === 'superadmin') { %>

    new Chart(document.getElementById('assetDoughnut'), {
      type: 'doughnut',
      data: {
        labels: ['Available', 'Assigned', 'Maintenance', 'Retired'],
        datasets: [{
          data: [
            <%= availableAssets %>,
            <%= assignedAssets %>,
            <%= maintenanceAssets %>,
            <%= retiredAssets %>
          ],
          backgroundColor: ['#43D9A2', '#6C63FF', '#FFA94D', '#FF6B6B'],
          borderWidth: 2,
          borderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { padding: 15, font: { size: 12 } }
          }
        }
      }
    });

    const deptNames = <%- JSON.stringify(assetsByDept.map(d => d.name)) %>;
    const deptAssets = <%- JSON.stringify(assetsByDept.map(d => d.count)) %>;

    new Chart(document.getElementById('assetBar'), {
      type: 'bar',
      data: {
        labels: deptNames,
        datasets: [{
          label: 'Assets',
          data: deptAssets,
          backgroundColor: [
            '#6C63FF','#43D9A2','#FF6B6B',
            '#FFA94D','#4DABF7','#F06595',
            '#74C0FC','#A9E34B'
          ],
          borderRadius: 6,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { stepSize: 1 },
            grid: { color: '#f0f0f0' }
          },
          x: { grid: { display: false } }
        }
      }
    });

    <% } %>

    // ── DEPT ADMIN CHARTS ──────────────────────
    <% if (role === 'admin') { %>

    new Chart(document.getElementById('assetDoughnut2'), {
      type: 'doughnut',
      data: {
        labels: ['Available', 'Assigned', 'Maintenance'],
        datasets: [{
          data: [
            <%= availableAssets %>,
            <%= assignedAssets %>,
            <%= maintenanceAssets %>
          ],
          backgroundColor: ['#43D9A2', '#6C63FF', '#FF6B6B'],
          borderWidth: 2,
          borderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { padding: 15, font: { size: 12 } }
          }
        }
      }
    });

    new Chart(document.getElementById('ticketBar'), {
      type: 'bar',
      data: {
        labels: ['Open', 'In Progress', 'Resolved', 'Closed'],
        datasets: [{
          label: 'Tickets',
          data: [
            <%= openTickets %>,
            <%= inProgressTickets %>,
            <%= resolvedTickets %>,
            <%= closedTickets %>
          ],
          backgroundColor: ['#FF6B6B', '#FFA94D', '#43D9A2', '#6C63FF'],
          borderRadius: 6,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { stepSize: 1 },
            grid: { color: '#f0f0f0' }
          },
          x: { grid: { display: false } }
        }
      }
    });

    <% } %>
  </script>

</body>
</html>